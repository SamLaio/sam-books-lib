; Calibre 圖書庫根目錄
; Docker 開發模式下通常維持 `/books`
CALIBRE_LIBRARY_PATH=/books

; 站台標題
; 會套用到網站頁面標題與 OPDS feed 名稱
SITE_TITLE=三姆的測試書庫

; 介面語系（zhTW / en）
; 若未設定則預設為 zhTW
APP_LOCALE=zhTW

; 站台對外網址
; 建議填可被閱讀器或區網裝置存取的網址，不要加結尾 `/`
SITE_BASE_URL=http://127.0.0.1:8083

; 預設主題（light=白天，dark=夜間）
; 當帳號尚未設定個人主題時，會使用這個預設值
SITE_DEFAULT_THEME=light

; 書目預設排序欄位（is_read/title/author/series/added_at）
; added_at = 以 Calibre 新增時間（若缺少則回退索引建立時間）
CATALOG_DEFAULT_SORT_FIELD=added_at

; 書目預設排序方向（asc/desc）
CATALOG_DEFAULT_SORT_DIRECTION=desc

; OPDS 單頁顯示上限
; 可依閱讀器體驗調整，每頁 1 到 500 筆，預設 30
OPDS_PAGE_SIZE=30

; SMTP 設定（有填完整才啟用寄信功能）
SMTP_HOST=
SMTP_PORT=
SMTP_ENCRYPTION=none
SMTP_USERNAME=
SMTP_PASSWORD=

; 是否啟用登入制度（1=啟用，0=停用）
AUTH_ENABLED=0

; 初始登入帳號與密碼（僅在首次且 users 為空時自動建立）
AUTH_USERNAME=admin
AUTH_PASSWORD=password123
AUTH_EMAIL=

; 帳號設定 SQLite 路徑（儲存帳號與 API Token）
; 也同時作為日常運行資料庫（例如掃描排程 scan_jobs 表）
AUTH_SETTINGS_DB_PATH=data/auth_settings.sqlite

; Migration 記錄 SQLite 路徑（專門記錄 auth / library 兩顆資料庫的 migration 歷程）
MIGRATIONS_DB_PATH=data/migrations.sqlite

; 登入密碼 hash pepper key（未設定時會在 data/auth.key 自動產生亂數）
; 舊版 data/auth.secret 會作為相容 fallback
AUTH_SECRET_KEY=

; SQLite 索引檔路徑
; 相對路徑會以 `site/` 目錄為基準
SQLITE_INDEX_PATH=data/library_index.sqlite

; 自動掃描最小間隔，單位為分鐘
; Docker 內的 cron 每分鐘都會觸發一次 job，但只有超過這個間隔才會真的執行掃描
; 設為 0 代表完全關閉自動掃描（仍可手動重建）
SCAN_INTERVAL_MINUTES=5

; 掃描重建分批寫入筆數
; 每掃描完成這個筆數就會先寫入 SQLite 再繼續下一批，建議 20~200
SCAN_BATCH_SIZE=50

; 每次掃描最多處理書目數量
; 僅限制「不在 calibre db 的路徑（source_type=fs）」每輪處理數量，0 代表不限制
SCAN_MAX_BOOKS_PER_RUN=500

; 掃描暫存 SQLite 路徑
; 建議使用容器內的 `/tmp`，可降低 Windows 掛載磁碟上的 SQLite I/O 錯誤機率
SCAN_TMP_SQLITE_PATH=/tmp/books-scan.tmp.sqlite

; 掃描 watchdog 逾時秒數
; 超過此秒數的舊掃描程序會嘗試中止（不清除 flag/tmp，保留接續狀態）
; 設為 0 可停用 watchdog
SCAN_WATCHDOG_TIMEOUT_SECONDS=180

; ===== Docker / 容器層預設（供 docker-compose 作為預設值來源）=====

; 容器內使用者與時區
HOME=/root
PUID=1000
PGID=1000
TZ=Asia/Taipei

; Web 根目錄（shinsenter/phpfpm-nginx 使用）
WEBHOME=/var/www/html

; PHP-FPM 行為
PHP_PM=ondemand
PHP_PM_MAX_CHILDREN=1
PHP_PM_START_SERVERS=1
PHP_PM_MIN_SPARE_SERVERS=1
PHP_PM_MAX_SPARE_SERVERS=1
PHP_PM_MAX_REQUESTS=120
PHP_MEMORY_LIMIT=64M
PHP_OPCACHE_ENABLE=0

; Composer 根套件版本（避免容器啟動時警告）
COMPOSER_ROOT_VERSION=v2.6.5

; 宿主機書庫路徑（docker-compose 的 volume source 使用）
; Windows/WSL 範例：/mnt/d/CalibreLib
BOOKS_LIBRARY_DIR=/mnt/d/CalibreLib
